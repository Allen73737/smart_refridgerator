<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/glass_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SMRIDGE 🧊"
        android:textColor="#00F2FF"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:letterSpacing="0.1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">
        <TextView android:id="@+id/temp_value" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:text="--" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:gravity="center" />
        <TextView android:id="@+id/hum_value" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:text="--" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:gravity="center" />
        <TextView android:id="@+id/freshness_value" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:text="--" android:textColor="#00F2FF" android:textSize="20sp" android:textStyle="bold" android:gravity="center" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:text="TEMP" android:textColor="#99FFFFFF" android:textSize="9sp" android:gravity="center" />
        <TextView android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:text="HUMIDITY" android:textColor="#99FFFFFF" android:textSize="9sp" android:gravity="center" />
        <TextView android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:text="FRESHNESS" android:textColor="#00F2FF" android:textSize="9sp" android:gravity="center" />
    </LinearLayout>

    <TextView android:id="@+id/status_text" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FF004D" android:textSize="12sp" android:gravity="center" android:layout_marginTop="6dp" android:textStyle="bold" />
    <TextView android:id="@+id/door_value" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#00F2FF" android:textSize="10sp" android:gravity="center" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="vertical" android:layout_marginTop="8dp">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="INVENTORY" android:textStyle="bold" android:textColor="#00F2FF" android:textSize="10sp" android:letterSpacing="0.05" />
        <TextView android:id="@+id/inventory_text" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="12sp" android:maxLines="3" android:ellipsize="end" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="ALERTS" android:textStyle="bold" android:textColor="#00F2FF" android:textSize="10sp" android:layout_marginTop="6dp" android:letterSpacing="0.05" />
        <TextView android:id="@+id/notifications_text" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FF004D" android:textSize="12sp" android:maxLines="2" android:ellipsize="end" />
    </LinearLayout>
</LinearLayout>
