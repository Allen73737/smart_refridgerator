<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/glass_bg"
    android:padding="12dp">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MY SMRIDGE"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="#40FFFFFF" />
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CHRONO"
            android:textColor="#00E5FF"
            android:textSize="10sp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Timer List (Simulated with fixed rows for RemoteViews stability) -->
    <LinearLayout
        android:id="@+id/timer_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:orientation="vertical">

        <!-- Row 1 -->
        <RelativeLayout
            android:id="@+id/timer_row_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:background="#1AFFFFFF"
            android:padding="8dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/timer_name_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Item 1"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp" />
            <Chronometer
                android:id="@+id/timer_val_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:textColor="#00E5FF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Row 2 -->
        <RelativeLayout
            android:id="@+id/timer_row_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:background="#1AFFFFFF"
            android:padding="8dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/timer_name_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Item 2"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp" />
            <Chronometer
                android:id="@+id/timer_val_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:textColor="#00E5FF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Row 3 -->
        <RelativeLayout
            android:id="@+id/timer_row_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:background="#1AFFFFFF"
            android:padding="8dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/timer_name_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Item 3"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp" />
            <Chronometer
                android:id="@+id/timer_val_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:textColor="#00E5FF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Empty State -->
        <TextView
            android:id="@+id/empty_state_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No active timers. 🧊"
            android:gravity="center"
            android:textColor="#80FFFFFF"
            android:textSize="12sp"
            android:padding="20dp"
            android:visibility="visible" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:text="SMART REFRIGERATOR SYSTEM"
        android:textColor="#40FFFFFF"
        android:textSize="8sp" />

</RelativeLayout>
